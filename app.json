{
  "expo": {
    "name": "NutriKidney",
    "slug": "nutrikidney",
    "scheme": "nutrikidney",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nutrikidney.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.nutrikidney.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "NutriKidney needs camera access to scan your meals."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "NutriKidney needs photo library access to upload meal photos."
        }
      ],
      "react-native-fast-tflite",
      "./plugins/withNoCompressTflite",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c2dd0144-d6d1-443e-9fc2-a16ca68b3268"
      }
    }
  }
}
